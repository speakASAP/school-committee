# ============================================
# Identity
# ============================================
NODE_ENV=
SERVICE_NAME=school-committee
DOMAIN=                # e.g. strilkove.cz — used in email header/footer branding sent via auth-microservice

# ============================================
# Ports
# ============================================
PORT=4800

# ============================================
# Application
# ============================================
APP_BASE_URL=http://localhost:4800

# ============================================
# Auth Microservice
# ============================================
AUTH_SERVICE_BASE_URL=http://auth-microservice:3370
AUTH_SERVICE_AUDIENCE=school-committee

# ============================================
# Database (shared PostgreSQL via Prisma)
# ============================================
DB_HOST=192.168.88.53
DB_PORT=5432
DB_USER=dbadmin
DB_NAME=school_committee_platform
# DB_SERVICE_TOKEN is the password — comes from Vault in production

# ============================================
# Logging Microservice
# ============================================
LOGGING_SERVICE_URL=http://logging-microservice:3367
LOGGING_SERVICE_API_PATH=/api/logs

# ============================================
# Notifications Microservice
# ============================================
NOTIFICATION_SERVICE_BASE_URL=http://notifications-microservice:3368

# ============================================
# Localization
# ============================================
DEFAULT_LOCALE=cs
SUPPORTED_LOCALES=cs,en,ru,uk

# ============================================
# Public Report
# ============================================
PUBLIC_REPORT_CACHE_TTL_SECONDS=300

# ============================================
# Secrets (from Vault in production — fake values for local dev only)
# ============================================

# Auth service client secret
AUTH_SERVICE_CLIENT_SECRET=changeme-local-only

# DB service bearer token
DB_SERVICE_TOKEN=changeme-local-only

# Payment account (Czech bank — spolek account)
PAYMENT_WEBHOOK_SECRET=changeme-local-only
PAYMENT_ACCOUNT_IBAN=changeme-local-only
PAYMENT_ACCOUNT_NUMBER=changeme-local-only
PAYMENT_BANK_CODE=changeme-local-only

# Email / SMTP
SMTP_HOST=localhost
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@school-committee.local

# Storage (MinIO)
STORAGE_ACCESS_KEY=changeme-local-only
STORAGE_SECRET_KEY=changeme-local-only
STORAGE_BUCKET=school-committee

# AI Microservice (voice transcription)
AI_SERVICE_BASE_URL=http://ai-microservice:3380

# ============================================
# Leads Microservice
# ============================================
# Public, no auth required for submit endpoint
LEADS_SERVICE_URL=https://leads.alfares.cz
