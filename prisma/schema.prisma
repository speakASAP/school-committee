generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  schools    School[]
  profiles   Profile[]
  userRoles  UserRole[]
  auditLogs  AuditLog[]

  @@map("tenants")
}

model School {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  address      String?
  contactEmail String?  @map("contact_email")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id])
  classes                    Class[]
  profiles                   Profile[]
  children                   Child[]
  userRoles                  UserRole[]
  contributionPlans          ContributionPlan[]
  paymentIntents             PaymentIntent[]
  expenses                   Expense[]
  tasks                      Task[]
  feedbackItems              FeedbackItem[]
  ideas                      Idea[]
  events                     Event[]
  auditLogs                  AuditLog[]

  @@map("schools")
}

model Class {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  schoolYear    String   @map("school_year")
  grade         String
  name          String
  teacherUserId String?  @map("teacher_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  school       School         @relation(fields: [schoolId], references: [id])
  children     Child[]
  tasks        Task[]
  feedbackItems FeedbackItem[]
  ideas        Idea[]

  @@map("classes")
}

model Profile {
  userId             String   @id @map("user_id") @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  schoolId           String   @map("school_id") @db.Uuid
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  phone              String?
  language           String   @default("cs")
  participationType  String   @map("participation_type")
  onboardingStatus   String   @default("incomplete") @map("onboarding_status")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  @@map("profiles")
}

model Child {
  id            String   @id @default(uuid()) @db.Uuid
  parentUserId  String   @map("parent_user_id") @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  classId       String   @map("class_id") @db.Uuid
  displayLabel  String?  @map("display_label")
  birthYear     Int?     @map("birth_year")
  parentConsent Boolean  @default(true) @map("parent_consent")
  createdAt     DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])

  @@map("children")
}

model UserRole {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  schoolId   String?   @map("school_id") @db.Uuid
  role       String
  assignedBy String?   @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  school School? @relation(fields: [schoolId], references: [id])

  @@map("user_roles")
}

model ContributionPlan {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  amountCzk Int      @map("amount_czk")
  period    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  school         School          @relation(fields: [schoolId], references: [id])
  paymentIntents PaymentIntent[]

  @@map("contribution_plans")
}

model PaymentIntent {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  planId         String?   @map("plan_id") @db.Uuid
  amountCzk      Int       @map("amount_czk")
  currency       String    @default("CZK")
  variableSymbol String    @unique @map("variable_symbol")
  message        String?
  status         String    @default("pending")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  paidAt         DateTime? @map("paid_at")

  school                     School                       @relation(fields: [schoolId], references: [id])
  plan                       ContributionPlan?            @relation(fields: [planId], references: [id])
  paymentReconciliationEvents PaymentReconciliationEvent[]

  @@map("payment_intents")
}

model PaymentReconciliationEvent {
  id              String   @id @default(uuid()) @db.Uuid
  paymentIntentId String?  @map("payment_intent_id") @db.Uuid
  source          String
  amountCzk       Int      @map("amount_czk")
  variableSymbol  String?  @map("variable_symbol")
  bankTransactionId String? @map("bank_transaction_id")
  rawReference    String?  @map("raw_reference")
  matchedBy       String?  @map("matched_by")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  paymentIntent PaymentIntent? @relation(fields: [paymentIntentId], references: [id])

  @@map("payment_reconciliation_events")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  title         String
  description   String?
  category      String
  amountCzk     Int      @map("amount_czk")
  spentAt       DateTime @map("spent_at") @db.Date
  receiptFileId String?  @map("receipt_file_id") @db.Uuid
  publicVisible Boolean  @default(false) @map("public_visible")
  createdBy     String   @map("created_by") @db.Uuid
  approvedBy    String?  @map("approved_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id])

  @@map("expenses")
}

model Task {
  id            String    @id @default(uuid()) @db.Uuid
  schoolId      String    @map("school_id") @db.Uuid
  classId       String?   @map("class_id") @db.Uuid
  title         String
  description   String
  deadline      DateTime? @db.Date
  priority      String    @default("normal")
  status        String    @default("open")
  createdBy     String    @map("created_by") @db.Uuid
  audioFileId   String?   @map("audio_file_id") @db.Uuid
  rawTranscript String?   @map("raw_transcript")
  aiDraftMeta   Json?     @map("ai_draft_meta")
  assignedTo    String?   @map("assigned_to") @db.Uuid
  verifiedBy    String?   @map("verified_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  school        School             @relation(fields: [schoolId], references: [id])
  class         Class?             @relation(fields: [classId], references: [id])
  comments      TaskComment[]
  statusEvents  TaskStatusEvent[]
  photos        TaskPhoto[]
  videos        TaskVideo[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_comments")
}

model TaskStatusEvent {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @map("task_id") @db.Uuid
  oldStatus   String?  @map("old_status")
  newStatus   String   @map("new_status")
  actorUserId String   @map("actor_user_id") @db.Uuid
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_status_events")
}

model TaskPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  fileExt   String   @default("jpg") @map("file_ext")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_photos")
}

model TaskVideo {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  fileId    String   @map("file_id") @db.Uuid
  fileExt   String   @default("mp4") @map("file_ext")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_videos")
}

model FeedbackItem {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  classId     String?  @map("class_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  category    String
  type        String
  text        String
  voiceFileKey  String?  @map("voice_file_key")
  voiceTranscript String? @map("voice_transcript")
  status      String   @default("new")
  moderatedBy String?  @map("moderated_by") @db.Uuid
  assignedTo  String?  @map("assigned_to") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  school School  @relation(fields: [schoolId], references: [id])
  class  Class?  @relation(fields: [classId], references: [id])

  @@map("feedback_items")
}

model Idea {
  id               String   @id @default(uuid()) @db.Uuid
  schoolId         String   @map("school_id") @db.Uuid
  classId          String?  @map("class_id") @db.Uuid
  submittedBy      String?  @map("submitted_by") @db.Uuid
  title            String
  description      String
  budgetNeededCzk  Int?     @map("budget_needed_czk")
  status           String   @default("submitted")
  createdAt        DateTime @default(now()) @map("created_at")

  school School  @relation(fields: [schoolId], references: [id])
  class  Class?  @relation(fields: [classId], references: [id])
  votes  IdeaVote[]

  @@map("ideas")
}

model IdeaVote {
  id        String   @id @default(uuid()) @db.Uuid
  ideaId    String   @map("idea_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  voteType  String   @default("support") @map("vote_type")
  createdAt DateTime @default(now()) @map("created_at")

  idea Idea @relation(fields: [ideaId], references: [id])

  @@unique([ideaId, userId])
  @@map("idea_votes")
}

model Event {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  title       String
  description String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  location    String?
  capacity    Int?
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  school        School              @relation(fields: [schoolId], references: [id])
  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    String   @default("registered")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@map("event_registrations")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  schoolId    String?  @map("school_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  metadata    Json     @default("{}")
  requestId   String?  @map("request_id")
  ipHash      String?  @map("ip_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  school School? @relation(fields: [schoolId], references: [id])

  @@map("audit_logs")
}
